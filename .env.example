# ============================================================
# API-HU - Variables de entorno
# ============================================================
# Copia este archivo a ".env" y rellena solo la del proveedor que vayas a usar.
# El archivo ".env" está en .gitignore y NO debe subirse al repo.
#
# Formato "Seccion__Clave" (doble guion bajo) sobrescribe appsettings.json.
# ============================================================

# -----------------------------------------------------------
# Selector de proveedor de IA
# -----------------------------------------------------------
# Valores válidos: anthropic | gemini | openrouter
AI__Provider=gemini

# ===========================================================
# GEMINI (Google) - Free tier recomendado
# ===========================================================
# Obtén key gratis (sin tarjeta) en: https://aistudio.google.com/apikey
# Free tier: 1500 req/día, 1M tokens/día en gemini-2.0-flash
GEMINI_API_KEY=AIza-TU-API-KEY-AQUI

# Modelos: gemini-2.0-flash (rápido/free), gemini-2.0-flash-lite,
#          gemini-1.5-pro, gemini-1.5-flash
Gemini__Modelo=gemini-2.0-flash

# ===========================================================
# OPENROUTER - Aggregator con modelos free
# ===========================================================
# Obtén key gratis en: https://openrouter.ai/keys
# Free tier: 200 req/día, 20 req/min en modelos con sufijo ":free"
OPENROUTER_API_KEY=sk-or-TU-API-KEY-AQUI

# Modelos free: deepseek/deepseek-chat:free, meta-llama/llama-3.3-70b-instruct:free,
#               google/gemini-2.0-flash-exp:free
OpenRouter__Modelo=deepseek/deepseek-chat:free

# ===========================================================
# ANTHROPIC (Claude) - De pago, pay-as-you-go
# ===========================================================
# Obtén key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-TU-API-KEY-AQUI
Anthropic__Modelo=claude-sonnet-4-6

# -----------------------------------------------------------
# Base de datos (SQL Server)
# -----------------------------------------------------------
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=APIHU;User Id=sa;Password=CAMBIA_ESTO;TrustServerCertificate=True;MultipleActiveResultSets=true

# -----------------------------------------------------------
# Servidor
# -----------------------------------------------------------
PORT=5000
ASPNETCORE_ENVIRONMENT=Development

# -----------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------
RateLimiting__Enabled=true
RateLimiting__MaxRequests=100

# -----------------------------------------------------------
# API Key (seguridad del endpoint)
# -----------------------------------------------------------
ApiKey__Enabled=false
