# ============================================================
# API-HU - Variables de entorno
# ============================================================
# Copia este archivo a ".env" y rellena los valores reales.
# El archivo ".env" está en .gitignore y NO debe subirse al repo.
#
# Todas las variables que siguen el formato "Seccion__Clave" (doble guion bajo)
# sobrescriben la configuración correspondiente en appsettings.json.
# ============================================================

# -----------------------------------------------------------
# Anthropic (Claude) - Proveedor de IA
# -----------------------------------------------------------
# La API Key se lee primero de ANTHROPIC_API_KEY y si no existe, de Anthropic:ApiKey
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo por defecto. Opciones:
#   claude-sonnet-4-6             (recomendado, balance calidad/coste)
#   claude-opus-4-6               (máxima calidad)
#   claude-haiku-4-5-20251001     (más rápido y barato)
Anthropic__Modelo=claude-sonnet-4-6

# Parámetros opcionales (si no se definen, usa appsettings.json)
Anthropic__Temperatura=0.3
Anthropic__MaxTokens=4096
Anthropic__MaximoReintentos=3
Anthropic__TimeoutSegundos=120

# -----------------------------------------------------------
# Base de datos (SQL Server)
# -----------------------------------------------------------
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=APIHU;User Id=sa;Password=CAMBIA_ESTO;TrustServerCertificate=True;MultipleActiveResultSets=true

# -----------------------------------------------------------
# Servidor
# -----------------------------------------------------------
PORT=5000
ASPNETCORE_ENVIRONMENT=Development

# -----------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------
RateLimiting__Enabled=true
RateLimiting__MaxRequests=100

# -----------------------------------------------------------
# API Key (seguridad del endpoint)
# -----------------------------------------------------------
# Si lo activas, los clientes deben mandar el header X-API-Key
ApiKey__Enabled=false
# Lista separada por comas
# ApiKey__ValidKeys__0=clave-cliente-1
# ApiKey__ValidKeys__1=clave-cliente-2
