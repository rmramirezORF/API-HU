{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PORT": "5000",
  "AI": {
    "Provider": "gemini",
    "ProviderChain": "gemini,groq,openrouter"
  },
  "Gemini": {
    "ApiKey": "",
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta",
    "Modelo": "gemini-2.5-flash",
    "ModelosFallback": [
      "gemini-2.5-flash-lite"
    ],
    "Temperatura": 0.1,
    "MaxTokens": 16384,
    "MaximoReintentos": 1,
    "BackoffBaseMs": 500,
    "TimeoutSegundos": 60
  },
  "OpenRouter": {
    "ApiKey": "",
    "BaseUrl": "https://openrouter.ai/api/v1",
    "Modelo": "google/gemma-3-27b-it:free",
    "ModelosFallback": [
      "qwen/qwen3-next-80b-a3b-instruct:free",
      "openai/gpt-oss-120b:free",
      "openai/gpt-oss-20b:free",
      "inclusionai/ling-2.6-flash:free",
      "nvidia/nemotron-3-nano-30b-a3b:free",
      "nousresearch/hermes-3-llama-3.1-405b:free",
      "google/gemma-4-31b-it:free",
      "z-ai/glm-4.5-air:free"
    ],
    "Temperatura": 0.1,
    "MaxTokens": 16384,
    "MaximoReintentos": 1,
    "BackoffBaseMs": 500,
    "TimeoutSegundos": 120,
    "AppName": "API-HU"
  },
  "Groq": {
    "ApiKey": "",
    "BaseUrl": "https://api.groq.com/openai/v1",
    "Modelo": "llama-3.3-70b-versatile",
    "ModelosFallback": [
      "openai/gpt-oss-120b",
      "qwen/qwen3-32b",
      "openai/gpt-oss-20b",
      "llama-3.1-8b-instant"
    ],
    "Temperatura": 0.1,
    "MaxTokens": 16384,
    "MaximoReintentos": 1,
    "BackoffBaseMs": 500,
    "TimeoutSegundos": 60
  },
  "RateLimiting": {
    "Enabled": true,
    "MaxRequests": 100,
    "Window": "00:01:00"
  },
  "ApiKey": {
    "Enabled": false,
    "ValidKeys": []
  },
  "Pipeline": {
    "ValidarHUs": true,
    "ValidarEstructura": true,
    "MaximoHUsPorRequest": 10,
    "TimeoutTotalSegundos": 300
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/apihu-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}
